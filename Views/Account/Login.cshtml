@model LoginViewModel

<form asp-action="Login" method="post" class="registration-form">
    <h2>Sign In</h2>
    <div asp-validation-summary="All" class="validation-message"></div>

    <div class="form-row">
        <label asp-for="Email"></label>
        <input asp-for="Email" type="email" />
        <span asp-validation-for="Email" class="validation-message"></span>
    </div>
    <div class="form-row">
        <label asp-for="Password"></label>
        <input asp-for="Password" type="password" />
        <span asp-validation-for="Password" class="validation-message"></span>
    </div>
    <div class="form-row">
        <label asp-for="RememberMe"></label>
        <input asp-for="RememberMe" type="checkbox" />
    </div>
    <button type="submit">Login</button>
</form>

<partial name="_ValidationScriptsPartial" />
